{
  "expo": {
    "name": "BALIKOS",
    "slug": "balikos",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "balikos",
    "extra": {
      "apiBase": "https://balikos.balisantih.com/api/balikos",
      "portalOrigin": "https://balikos.balisantih.com",
      "googleWebClientId": "",
      "googleAndroidClientId": ""
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo-balikos.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7fbff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "id.balisantih.balikos",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#063a8f"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
